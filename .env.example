# ===================================================================
# FRONTEND ENVIRONMENT VARIABLES
# ===================================================================

# Development: Backend URL for Vite dev server proxy
# This is used by vite.config.ts when running locally
VITE_BACKEND_URL=http://localhost:8080

# API Base URL for axios
# - Development: Use relative /api path to leverage Vite proxy
# - Production: Leave empty to use relative /api path (Vercel will proxy to backend)
VITE_API_BASE_URL=/api

# Production Backend URL (used by Vercel rewrites)
# Set this in Vercel environment variables
BACKEND_URL=https://your-backend-url.com
